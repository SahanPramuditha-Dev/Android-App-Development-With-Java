<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".PortfolioActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="32dp">

        <!-- Background Header with subtle gradient/dark feel -->
        <View
            android:id="@+id/headerBackground"
            android:layout_width="match_parent"
            android:layout_height="240dp"
            android:background="@color/surface"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivProfile"
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:layout_marginTop="48dp"
            android:padding="3dp"
            android:src="@drawable/profile_photo"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:shapeAppearanceOverlay="@style/CircleImage"
            app:strokeColor="@color/primary"
            app:strokeWidth="2dp" />

        <TextView
            android:id="@+id/tvProfileName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Sahan"
            android:textColor="@color/text_primary"
            android:textSize="28sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/ivProfile" />

        <TextView
            android:id="@+id/tvProfileRole"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Java Developer | Mobile App Enthusiast"
            android:textColor="@color/primary"
            android:textSize="16sp"
            android:letterSpacing="0.05"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvProfileName" />

        <GridLayout
            android:id="@+id/gridMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="16dp"
            android:columnCount="2"
            app:layout_constraintTop_toBottomOf="@+id/headerBackground">

            <!-- About Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardAbout"
                style="@style/PortfolioCard"
                android:layout_width="0dp"
                android:layout_height="150dp"
                android:layout_columnWeight="1"
                android:layout_margin="8dp">
                <LinearLayout style="@style/CardInnerLayout">
                    <ImageView android:layout_width="44dp" android:layout_height="44dp" android:src="@android:drawable/ic_menu_info_details" app:tint="@color/primary" />
                    <TextView style="@style/CardText" android:text="About Me" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Skills Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardSkills"
                style="@style/PortfolioCard"
                android:layout_width="0dp"
                android:layout_height="150dp"
                android:layout_columnWeight="1"
                android:layout_margin="8dp">
                <LinearLayout style="@style/CardInnerLayout">
                    <ImageView android:layout_width="44dp" android:layout_height="44dp" android:src="@android:drawable/ic_menu_manage" app:tint="@color/primary" />
                    <TextView style="@style/CardText" android:text="Skills" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Projects Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardProjects"
                style="@style/PortfolioCard"
                android:layout_width="0dp"
                android:layout_height="150dp"
                android:layout_columnWeight="1"
                android:layout_margin="8dp">
                <LinearLayout style="@style/CardInnerLayout">
                    <ImageView android:layout_width="44dp" android:layout_height="44dp" android:src="@android:drawable/ic_menu_view" app:tint="@color/primary" />
                    <TextView style="@style/CardText" android:text="Projects" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Experience Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardExperience"
                style="@style/PortfolioCard"
                android:layout_width="0dp"
                android:layout_height="150dp"
                android:layout_columnWeight="1"
                android:layout_margin="8dp">
                <LinearLayout style="@style/CardInnerLayout">
                    <ImageView android:layout_width="44dp" android:layout_height="44dp" android:src="@android:drawable/ic_menu_recent_history" app:tint="@color/primary" />
                    <TextView style="@style/CardText" android:text="Experience" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Education Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardEducation"
                style="@style/PortfolioCard"
                android:layout_width="0dp"
                android:layout_height="150dp"
                android:layout_columnWeight="1"
                android:layout_margin="8dp">
                <LinearLayout style="@style/CardInnerLayout">
                    <ImageView android:layout_width="44dp" android:layout_height="44dp" android:src="@android:drawable/ic_menu_myplaces" app:tint="@color/primary" />
                    <TextView style="@style/CardText" android:text="Education" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Achievements Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardAchievements"
                style="@style/PortfolioCard"
                android:layout_width="0dp"
                android:layout_height="150dp"
                android:layout_columnWeight="1"
                android:layout_margin="8dp">
                <LinearLayout style="@style/CardInnerLayout">
                    <ImageView android:layout_width="44dp" android:layout_height="44dp" android:src="@android:drawable/btn_star_big_on" app:tint="@color/primary" />
                    <TextView style="@style/CardText" android:text="Achievements" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </GridLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnContact"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginStart="24dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="24dp"
            android:text="Contact Me"
            android:textAllCaps="false"
            android:textSize="16sp"
            app:cornerRadius="16dp"
            app:layout_constraintTop_toBottomOf="@+id/gridMenu"
            app:icon="@android:drawable/ic_menu_send"
            app:iconGravity="textStart" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>